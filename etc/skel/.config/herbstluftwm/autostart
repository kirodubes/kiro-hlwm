#!/usr/bin/env bash
# =============================================================================
# autostart — herbstluftwm session config (Kiro edition)
#
# herbstluftwm runs THIS file on login and on every `herbstclient reload`
# (super+shift+r). It is both the window-manager config (keybindings, rules,
# tags, theme — set live via herbstclient) AND the session autostart (tray
# applets, compositor, wallpaper, status bar). herbstluftwm is the "called-by-WM"
# autostart family: there is no separate run.sh and no window-manager loop.
#
# To autostart your own apps, add:  run "your-app"
# To stop an autostart entry, comment it out with #
# To change a keybinding, edit its `hc keybind …` line and press super+shift+r.
# =============================================================================

hc() { herbstclient "$@"; }

# run() — start a program only if it is not already running. `herbstclient
# reload` re-runs this whole file, so the exact-match pgrep guard stops the tray
# applets from stacking up duplicates on every reload.
run() {
  if ! pgrep -x "$(basename "$1" | head -c 15)" >/dev/null; then
    "$@" &
  fi
}

hc emit_hook reload

# Reset — start from a clean slate on every reload.
hc keyunbind --all
hc mouseunbind --all
hc unrule -F

# ── Modifier ──────────────────────────────────────────────────────────────────
# SUPER (Mod4) is the main modifier, matching the rest of the Kiro TWM family.
Mod=Mod4

# ── Applications & launchers ──────────────────────────────────────────────────
# NOTE: herbstclient `spawn` execs directly (no shell), so ~ is NOT expanded —
# use $HOME for paths passed to spawn. $HOME resolves per-user at login.
ROFI="rofi -no-config -no-lazy-grab -show drun -modi drun -theme $HOME/.config/herbstluftwm/rofi/launcher.rasi"
hc keybind $Mod-Return          spawn alacritty                     # terminal
hc keybind $Mod-t               spawn alacritty                     # terminal
hc keybind $Mod-KP_Enter        spawn alacritty                     # terminal (numpad)
hc keybind Control-Mod1-Return  spawn alacritty                     # terminal
hc keybind Control-Mod1-t       spawn alacritty                     # terminal
hc keybind $Mod-Shift-Return    spawn thunar                        # file manager
hc keybind $Mod-space           spawn $ROFI                         # app launcher
hc keybind $Mod-r               spawn $ROFI                         # app launcher
hc keybind $Mod-d               spawn $ROFI                         # app launcher
hc keybind $Mod-e               spawn code                          # editor
hc keybind $Mod-v               spawn pavucontrol                   # audio mixer
hc keybind $Mod-F1              spawn vivaldi-stable                 # browser
hc keybind $Mod-F2              spawn code                          # editor
hc keybind $Mod-F3              spawn inkscape
hc keybind $Mod-F4              spawn gimp
hc keybind $Mod-F5              spawn meld
hc keybind $Mod-F6              spawn vlc
hc keybind $Mod-F7              spawn virtualbox
hc keybind $Mod-F8              spawn thunar
hc keybind $Mod-F9              spawn virt-manager
hc keybind $Mod-F10             spawn spotify
hc keybind $Mod-F11             spawn $ROFI                         # app launcher
hc keybind $Mod-F12             spawn $ROFI                         # app launcher
hc keybind Control-Mod1-f       spawn firefox                       # browser
hc keybind Control-Mod1-b       spawn brave                         # browser
hc keybind Control-Mod1-e       spawn archlinux-tweak-tool          # system tool
hc keybind Control-Mod1-p       spawn pamac-manager                 # package manager

# ── Window management ─────────────────────────────────────────────────────────
hc keybind $Mod-q               close                               # close window
hc keybind $Mod-Shift-q         close
hc keybind $Mod-Shift-c         close
hc keybind $Mod-f               fullscreen toggle                   # fullscreen
hc keybind $Mod-Shift-f         set_attr clients.focus.floating toggle   # float this window
hc keybind $Mod-s               floating toggle                     # float whole tag
hc keybind $Mod-y               pseudotile toggle                   # keep floating size when tiled
hc keybind $Mod-Shift-Escape    spawn xkill                         # force-kill a window

# Focus (hjkl + arrows)
hc keybind $Mod-h               focus left
hc keybind $Mod-j               focus down
hc keybind $Mod-k               focus up
hc keybind $Mod-l               focus right
hc keybind $Mod-Left            focus left
hc keybind $Mod-Down            focus down
hc keybind $Mod-Up              focus up
hc keybind $Mod-Right           focus right
hc keybind $Mod-c               cycle                               # cycle windows in frame
hc keybind $Mod-i               jumpto urgent                       # jump to urgent window

# Move / shift the focused window
hc keybind $Mod-Shift-h         shift left
hc keybind $Mod-Shift-j         shift down
hc keybind $Mod-Shift-k         shift up
hc keybind $Mod-Shift-l         shift right
hc keybind $Mod-Shift-Left      shift left
hc keybind $Mod-Shift-Down      shift down
hc keybind $Mod-Shift-Up        shift up
hc keybind $Mod-Shift-Right     shift right

# ── Frames & layout ───────────────────────────────────────────────────────────
resizestep=0.02
hc keybind $Mod-Control-h       resize left  +$resizestep
hc keybind $Mod-Control-j       resize down  +$resizestep
hc keybind $Mod-Control-k       resize up    +$resizestep
hc keybind $Mod-Control-l       resize right +$resizestep
hc keybind $Mod-o               split right  0.5                    # split frame → right
hc keybind $Mod-a               split bottom 0.5                    # split frame → below
hc keybind $Mod-Control-space   split explode                      # explode into subframes
hc keybind $Mod-w               remove                             # merge frame into parent
hc keybind $Mod-m               cycle_layout +1                    # cycle frame layout
hc keybind $Mod-p               cycle_layout +1 vertical horizontal max grid   # explicit layouts

# ── Tags (workspaces) ─────────────────────────────────────────────────────────
# QWERTY is the shipped default; a Belgian (be) layout auto-loads the AZERTY
# number-row keysyms. Never hardcode a layout.
tag_names=( 1 2 3 4 5 6 7 8 9 )
qwerty_keys=( 1 2 3 4 5 6 7 8 9 )
azerty_keys=( ampersand eacute quotedbl apostrophe parenleft section egrave exclam ccedilla )
layout=$(setxkbmap -query 2>/dev/null | awk '/^layout:/ {print $2}')
case ",$layout," in
  *,be,*) tag_keys=( "${azerty_keys[@]}" ) ;;
  *)      tag_keys=( "${qwerty_keys[@]}" ) ;;
esac
hc rename default "${tag_names[0]}" 2>/dev/null || true
for i in "${!tag_names[@]}" ; do
  hc add "${tag_names[$i]}"
  key="${tag_keys[$i]}"
  [ -n "$key" ] || continue
  hc keybind "$Mod-$key"       use_index "$i"      # switch to tag
  hc keybind "$Mod-Shift-$key" move_index "$i"     # send window to tag
done
hc keybind $Mod-Tab             use_previous                        # toggle previous tag
hc keybind $Mod-grave           use_index +1 --skip-visible         # next used tag
hc keybind $Mod-Shift-grave     use_index -1 --skip-visible         # previous used tag

# ── Multi-monitor ─────────────────────────────────────────────────────────────
hc keybind $Mod-comma           cycle_monitor -1                    # focus previous monitor
hc keybind $Mod-period          cycle_monitor +1                    # focus next monitor
hc keybind $Mod-BackSpace       cycle_monitor +1

# ── Session & desktop ─────────────────────────────────────────────────────────
hc keybind $Mod-Shift-r         reload                              # reload this config
hc keybind $Mod-x               spawn archlinux-logout              # logout dialog
hc keybind Control-Mod1-k       spawn archlinux-logout             # logout dialog
hc keybind Control-Mod1-l       spawn archlinux-logout --settings  # logout settings
hc keybind Control-Mod1-r       spawn archlinux-betterlockscreen   # lock screen
hc keybind $Mod-Shift-x         spawn edu-powermenu                # power menu
hc keybind $Mod-Control-s       spawn kiro-keybindings             # keybindings cheatsheet
hc keybind $Mod-b               spawn polybar-msg cmd toggle       # toggle status bar
hc keybind $Mod-g               spawn $HOME/.config/herbstluftwm/scripts/fastcompmgr-toggle.sh  # toggle compositor
hc keybind Control-Mod1-Shift-Delete  quit                         # quit herbstluftwm

# ── Screenshots ───────────────────────────────────────────────────────────────
hc keybind $Mod-u               spawn sh -c 'maim -s | xclip -selection clipboard -t image/png'   # region → clipboard
hc keybind $Mod-Control-u       spawn sh -c 'maim | xclip -selection clipboard -t image/png'      # full → clipboard
hc keybind Print                spawn sh -c 'maim ~/Pictures/screenshot-$(date +%F-%H%M%S).png'   # full → Pictures
hc keybind Control-Print        spawn xfce4-screenshooter                                         # interactive
hc keybind Control-Shift-Print  spawn flameshot gui                                               # flameshot

# ── Multimedia & hardware keys ────────────────────────────────────────────────
hc keybind XF86AudioRaiseVolume spawn pamixer -i 5
hc keybind XF86AudioLowerVolume spawn pamixer -d 5
hc keybind XF86AudioMute        spawn pamixer -t
hc keybind XF86AudioPlay        spawn playerctl play-pause
hc keybind XF86AudioNext        spawn playerctl next
hc keybind XF86AudioPrev        spawn playerctl previous
hc keybind XF86AudioStop        spawn playerctl stop
hc keybind XF86MonBrightnessUp   spawn brightnessctl set 5%+
hc keybind XF86MonBrightnessDown spawn brightnessctl set 5%-

# ── Mouse ─────────────────────────────────────────────────────────────────────
hc mousebind $Mod-Button1 move
hc mousebind $Mod-Button2 zoom
hc mousebind $Mod-Button3 resize

# ── Rules ─────────────────────────────────────────────────────────────────────
hc rule focus=on
hc rule floatplacement=smart
hc rule windowtype~'_NET_WM_WINDOW_TYPE_(DIALOG|UTILITY|SPLASH)' floating=on
hc rule windowtype='_NET_WM_WINDOW_TYPE_DIALOG' focus=on
hc rule windowtype~'_NET_WM_WINDOW_TYPE_(NOTIFICATION|DOCK|DESKTOP)' manage=off
hc rule fixedsize floating=on

# ── Theme ─────────────────────────────────────────────────────────────────────
hc attr theme.tiling.reset 1
hc attr theme.floating.reset 1
hc set frame_border_active_color '#5e81acff'   # Nord-ish active frame
hc set frame_border_normal_color '#3b4252ff'
hc set frame_bg_normal_color     '#2e3440aa'
hc set frame_bg_active_color     '#4c566aaa'
hc set frame_border_width 1
hc set frame_bg_transparent on
hc set frame_transparent_width 0
hc set frame_gap 6
hc set window_gap 6
hc set frame_padding 0
hc set smart_window_surroundings off
hc set smart_frame_surroundings on
hc set mouse_recenter_gap 0
hc set show_frame_decorations 'focused_if_multiple'
hc attr theme.title_height 0
hc attr theme.title_when never
hc attr theme.border_width 3
hc attr theme.floating.border_width 3
hc attr theme.active.color   '#5e81ac'
hc attr theme.normal.color   '#3b4252'
hc attr theme.urgent.color   '#bf616a'
hc attr theme.inner_width 0
hc attr theme.background_color '#2e3440'
hc set tree_style '╾│ ├└╼─┐'
hc unlock

# =============================================================================
# Session autostart (AUTOSTART_TEMPLATE common body)
# =============================================================================

# ── Default home folders ──────────────────────────────────────────────────────
# Create the standard XDG user dirs (Desktop, Downloads, …) on login, idempotently.
command -v xdg-user-dirs-update >/dev/null 2>&1 && xdg-user-dirs-update

# ── Monitor layout ────────────────────────────────────────────────────────────
# Apply a saved arandr/xrandr screen layout named after the current user.
# Generate your layout with arandr, save it to ~/.screenlayout/<username>.sh
# Uncomment the xrandr line below if you are running inside VirtualBox.
#run xrandr --output Virtual-1 --primary --mode 1920x1080 --pos 0x0 --rotate normal
[ -f "$HOME/.screenlayout/$(whoami).sh" ] && sh "$HOME/.screenlayout/$(whoami).sh"

# ── System tray applets ───────────────────────────────────────────────────────
run nm-applet                                        # NetworkManager wifi/eth tray
run pamac-tray                                       # Arch package manager tray
run xfce4-power-manager                              # Battery / display power management
run blueberry-tray                                   # Bluetooth manager tray
run /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1  # Polkit auth popups (sudo GUI)
run /usr/lib/xfce4/notifyd/xfce4-notifyd             # Desktop notification daemon

# ── Compositor ────────────────────────────────────────────────────────────────
# fastcompmgr is the lightweight default; toggle with super+g. One at a time.
run fastcompmgr -c

# ── Keyboard ──────────────────────────────────────────────────────────────────
run numlockx on                                      # Enable numlock on login
# herbstluftwm binds its own keys (see above) — no sxhkd is used. Tag number-row
# keysyms auto-adapt to a Belgian (be) layout in the Tags section.

# ── Wallpaper ─────────────────────────────────────────────────────────────────
# Restore the last wallpaper set by feh, else fall back to the default Kiro one.
if [ -f "$HOME/.fehbg" ]; then
    sh "$HOME/.fehbg" &
else
    feh --bg-fill ~/.config/herbstluftwm/bg/kiro.jpg &
fi

# ── Status bar ────────────────────────────────────────────────────────────────
# polybar, shipped inside this config dir. launch.sh restarts it on every reload
# and starts one bar per monitor with a herbstclient-driven tags module.
~/.config/herbstluftwm/polybar/launch.sh &
